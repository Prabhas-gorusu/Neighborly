rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users full access to requests
    match /requests/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users full access to users
    match /users/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users access to helpers
    match /helpers/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Default: authenticated users can read/write everything
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
